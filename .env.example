# Google Places API (optional, for enrichment)
# GOOGLE_PLACES_API_KEY=your_key_here

# Overpass API endpoint (default is public, change if you have a private instance)
OVERPASS_API_URL=https://overpass-api.de/api/interpreter

# Chatbot LLM (optional — leave blank or set to "none" for local deterministic mode)
# Supported providers: anthropic, openai, none
LLM_PROVIDER=none
# LLM_API_KEY=your_key_here

# Required for data refresh and RAG reindex endpoints.
# INVEST_SEARCH_ADMIN_TOKEN=replace-with-a-long-random-token

# ---------------------------------------------------------------------------
# Local RAG / Ollama (used when LLM_PROVIDER=ollama)
# ---------------------------------------------------------------------------
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
# Chat model. A/B eval (docs/model_comparison.md) found qwen3:8b and qwen2.5:7b
# statistically tied, with qwen2.5:7b slightly more faithful on numbers.
# Leave blank to auto-pick from installed models, or pin one explicitly:
# OLLAMA_CHAT_MODEL=qwen2.5:7b

# Generation budget (raised from 150 so the full 6-section note renders):
RAG_NUM_PREDICT=400
RAG_NUM_CTX=1536

# Retrieval (semantic + BM25 fused with Reciprocal Rank Fusion):
#   RAG_HYBRID_MODE: rrf (default) | semantic | lexical
#   RAG_MAX_PER_SOURCE: max chunks per source file in results (1 measured best)
#   RAG_RRF_K: RRF damping constant
RAG_HYBRID_MODE=rrf
RAG_MAX_PER_SOURCE=1
RAG_RRF_K=60
